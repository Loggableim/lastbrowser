+    html += `<div class="sm-result-item">
+      ${title ? `<div class="sm-result-title">${esc(title)}</div>` : ''}
+      <div class="sm-result-body">${esc(snippet)}</div>
+      <div class="sm-result-meta">${scoreHtml} ${timeHtml}</div>
+    </div>`;
+  }
+  resultsEl.innerHTML = html;
+}
