+// ── Patch accept/reject tracking ──
+let _patchIdCounter = 0;
+const PATCH_STATE_KEY = 'hermes_patch_states';
+
+function _getPatchStates() {
+  try {
+    return JSON.parse(sessionStorage.getItem(PATCH_STATE_KEY) || '{}');
+  } catch(e) { return {}; }
+}
+
+function _savePatchStates(states) {
+  try { sessionStorage.setItem(PATCH_STATE_KEY, JSON.stringify(states)); } catch(e) {}
+}
+
+function _initDiffActions() {
+  // Process diff blocks from both markdown code blocks and inline diff loads
+  document.querySelectorAll('.diff-block:not([data-diff-initialized])').forEach(diffBlock => {
+    diffBlock.setAttribute('data-diff-initialized', '1');
+
+    // Find the parent pre-header if it exists (from markdown rendering)
+    const preHeader = diffBlock.previousElementSibling && diffBlock.previousElementSibling.classList.contains('pre-header')
+      ? diffBlock.previousElementSibling
+      : null;
+
+    // Skip if already inside a wrapper
+    if (diffBlock.closest('.diff-wrapper')) return;
+
+    const patchId = 'patch_' + (++_patchIdCounter) + '_' + Date.now().toString(36);
+
+    // Get the raw diff text
+    const rawText = diffBlock.textContent || '';
+
+    // Create wrapper
+    const wrapper = document.createElement('div');
+    wrapper.className = 'diff-wrapper';
+    wrapper.dataset.patchId = patchId;
+
+    // Check for persisted state
+    const states = _getPatchStates();
+    if (states[patchId] === 'accepted') wrapper.dataset.accepted = '1';
+    if (states[patchId] === 'rejected') wrapper.dataset.rejected = '1';
+
+    // Re-parent: move pre-header and diff-block into wrapper
+    if (preHeader) {
+      preHeader.parentNode.insertBefore(wrapper, preHeader);
+      wrapper.appendChild(preHeader);
+    } else {
+      diffBlock.parentNode.insertBefore(wrapper, diffBlock);
+    }
+
+    // Move a preceding .msg-artifact-header or parent container if present (happens with diff-inline)
+    const inlineParent = diffBlock.closest('.diff-inline');
+    if (inlineParent && inlineParent.parentNode) {
+      // For diff-inline, wrap the whole thing
+      const parentWrapper = document.createElement('div');
+      parentWrapper.className = 'diff-wrapper';
+      parentWrapper.dataset.patchId = patchId;
+      if (states[patchId] === 'accepted') parentWrapper.dataset.accepted = '1';
+      if (states[patchId] === 'rejected') parentWrapper.dataset.rejected = '1';
+
+      inlineParent.parentNode.insertBefore(parentWrapper, inlineParent);
+      parentWrapper.appendChild(inlineParent);
+      // Remove the outer wrapper we created since we're using parentWrapper
+      if (wrapper.parentNode) wrapper.parentNode.removeChild(wrapper);
+
+      // Add buttons to parentWrapper instead
+      if (!parentWrapper.dataset.accepted && !parentWrapper.dataset.rejected) {
+        parentWrapper.insertAdjacentHTML('beforeend', _patchActionBarHtml(patchId, rawText));
+      }
+      return;
+    }
+
+    wrapper.appendChild(diffBlock);
+
+    // Add action buttons if not already accepted/rejected
+    if (!wrapper.dataset.accepted && !wrapper.dataset.rejected) {
+      wrapper.insertAdjacentHTML('beforeend', _patchActionBarHtml(patchId, rawText));
+    }
+  });
+}
+
+function _patchActionBarHtml(patchId, rawText) {
+  const acceptLabel = typeof t === 'function' ? t('diff_accept') || 'Accept' : 'Accept';
+  const rejectLabel = typeof t === 'function' ? t('diff_reject') || 'Reject' : 'Reject';
+  const editLabel = typeof t === 'function' ? t('diff_edit') || 'Edit' : 'Edit';
+  return `<div class="diff-actions" data-patch-id="${esc(patchId)}">
+    <button class="diff-action-btn diff-accept" onclick="applyPatch('${esc(patchId)}','accept',this)" title="${esc(acceptLabel)}">✓ ${esc(acceptLabel)}</button>
+    <button class="diff-action-btn diff-reject" onclick="applyPatch('${esc(patchId)}','reject',this)" title="${esc(rejectLabel)}">✗ ${esc(rejectLabel)}</button>
+    <button class="diff-action-btn diff-edit-btn" onclick="editPatchInline('${esc(patchId)}',this)" title="${esc(editLabel)}">✎ ${esc(editLabel)}</button>
+  </div>`;
+}
+
+async function applyPatch(patchId, action, btn) {
+  if (!btn) return;
+  btn.disabled = true;
+  
+  const wrapper = btn.closest('.diff-wrapper');
+  if (!wrapper) return;
+  
+  const rawText = wrapper.querySelector('.diff-block')?.textContent || '';
+  
+  try {
+    const resp = await fetch('/api/chat/apply-patch', {
+      method: 'POST',
+      headers: {'Content-Type': 'application/json'},
+      body: JSON.stringify({patchId, action, patch_content: rawText}),
+    });
+    const data = await resp.json();
+    
+    if (data.ok === false || data.error) {
+      console.error('Patch action failed:', data.error || 'unknown error');
+      btn.disabled = false;
+      // Show error briefly
+      const origText = btn.textContent;
+      btn.textContent = '✗ ' + (data.error || 'Failed');
+      btn.style.color = 'var(--error)';
+      setTimeout(() => { btn.textContent = origText; btn.style.color = ''; }, 2000);
+      return;
+    }
+    
+    // Success: mark state
+    const states = _getPatchStates();
+    states[patchId] = action;
+    _savePatchStates(states);
+    
+    if (action === 'accept') {
+      wrapper.dataset.accepted = '1';
+    } else if (action === 'reject') {
+      wrapper.dataset.rejected = '1';
+    }
+  } catch (e) {
+    console.error('Patch action failed:', e);
+    btn.disabled = false;
+  }
+}
+
+function editPatchInline(patchId, btn) {
+  const wrapper = btn.closest('.diff-wrapper');
+  if (!wrapper) return;
+  const codeEl = wrapper.querySelector('.diff-block code');
+  if (!codeEl) return;
+  
+  // Toggle contentEditable on the diff code block
+  const isEditing = codeEl.getAttribute('contenteditable') === 'true';
+  if (isEditing) {
+    codeEl.removeAttribute('contenteditable');
+    codeEl.classList.remove('diff-editing');
+    btn.textContent = (typeof t === 'function' ? t('diff_edit') || 'Edit' : 'Edit');
+    return;
+  }
+  
+  codeEl.setAttribute('contenteditable', 'true');
+  codeEl.classList.add('diff-editing');
+  btn.textContent = (typeof t === 'function' ? t('diff_done') || 'Done' : 'Done');
+  codeEl.focus();
+}
