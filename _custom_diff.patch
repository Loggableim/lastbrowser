+# ============================================================
+# Terminal command streaming SSE endpoint
+# ============================================================
+_SSE_COMMAND_STREAM_HEARTBEAT = 15
+
+
+def _handle_terminal_stream(handler, parsed):
+    """SSE endpoint for live agent terminal() command output.
+
+    Reads from CommandStreamSession.queue and dispatches SSE events:
+      - event: stdout  data: {"data": "..."}
+      - event: stderr  data: {"data": "..."}
+      - event: exit    data: {"code": 0}
+      - event: error   data: {"error": "..."}
+    """
+    from api.helpers import bad
+    from urllib.parse import parse_qs
+    from api.command_stream import get_command_stream, cleanup_session
+
+    qs = parse_qs(parsed.query)
+    sid = qs.get("session_id", [""])[0]
+    if not sid:
+        return bad(handler, "session_id required")
+
+    handler.send_response(200)
+    handler.send_header("Content-Type", "text/event-stream; charset=utf-8")
+    handler.send_header("Cache-Control", "no-cache")
+    handler.send_header("X-Accel-Buffering", "no")
+    handler.send_header("Connection", "keep-alive")
+    handler.end_headers()
+
+    try:
+        while True:
+            stream = get_command_stream(sid)
+            if stream is None:
+                try:
+                    handler.wfile.write(b": terminal stream heartbeat\n\n")
+                    handler.wfile.flush()
+                    import time as _t
+                    _t.sleep(_SSE_COMMAND_STREAM_HEARTBEAT)
+                except (BrokenPipeError, OSError):
+                    break
+                continue
+
+            try:
+                event, data = stream.output.get(timeout=_SSE_COMMAND_STREAM_HEARTBEAT)
+            except Exception:
+                try:
+                    handler.wfile.write(b": terminal stream heartbeat\n\n")
+                    handler.wfile.flush()
+                except (BrokenPipeError, OSError):
+                    break
+                if stream.finished.is_set() and stream.output.empty():
+                    break
+                continue
+
+            _sse(handler, event, data)
+            if event == "exit":
+                import time as _t2
+                _t2.sleep(0.25)
+                break
+    except (BrokenPipeError, ConnectionResetError, ConnectionAbortedError):
+        pass
+    finally:
+        cleanup_session(sid)
+
+    return True
