+  --focus-ring: rgba(0,255,65,.4);
+  --focus-glow: rgba(0,255,65,.15);
+  --input-bg: rgba(0,255,65,.08);
+  --hover-bg: rgba(0,255,65,.1);
+  --strong: #FFFFFF;
+  --em: #DDFFDD;
+  --code-text: #88FF88;
+  --code-inline-bg: rgba(0,0,0,.4);
+  --pre-text: #E8FFE8;
+  --accent-hover: #00DD33;
+  --accent-bg: rgba(0,255,65,0.12);
+  --accent-bg-strong: rgba(0,255,65,0.22);
+  --accent-text: #00FF41;
+  --error: #FF6666;
+  --success: #55FF55;
+  --warning: #FFBB33;
+  --info: #66DDFF;
+  --surface-subtle: rgba(0,255,65,.04);
+  --surface-subtle-hover: rgba(0,255,65,.07);
+  --border-subtle: rgba(0,255,65,.12);
+  --border-muted: rgba(0,255,65,.18);
+  --user-bubble-bg: #0F1C0F;
+  --user-bubble-border: rgba(0,255,65,0.25);
+  --user-bubble-text: #F0FFF0;
+  --user-bubble-placeholder: #55CC55;
+  --user-selection-bg: rgba(0,255,65,0.3);
+  --user-selection-text: #FFFFFF;
+  /* Simpler, highly readable font stack — Tahoma/Verdana are especially clear
+     at small sizes for users with visual impairments */
+  --font-ui: Tahoma, Verdana, "Segoe UI", Arial, Helvetica, sans-serif;
+}
+/* CRT scanline overlay — very subtle to preserve readability.
+   Reduced opacity so scanlines don't interfere with text contrast. */
+:root.dark[data-skin="matrix"] body {
+  background:
+    repeating-linear-gradient(
+      0deg,
+      transparent 0px, transparent 2px,
+      rgba(0,255,65,0.015) 2px, rgba(0,255,65,0.015) 4px
+    ),
+    var(--bg);
+}
+/* Phosphor glow on active matrix elements */
+:root.dark[data-skin="matrix"] .session-item.active {
+  box-shadow: inset 0 0 12px rgba(0,255,65,0.08);
+}
+:root.dark[data-skin="matrix"] .session-item.active .session-title,
+:root.dark[data-skin="matrix"] .session-item.active .session-meta {
+  text-shadow: 0 0 6px rgba(0,255,65,0.4);
+}
+:root.dark[data-skin="matrix"] .session-item.streaming .session-title {
+  text-shadow: 0 0 8px rgba(0,255,65,0.5);
+}
+:root.dark[data-skin="matrix"] .session-item.active .session-time,
+:root.dark[data-skin="matrix"] .session-item:hover .session-time {
+  color: var(--accent);
+}
+/* Logo: green gradient instead of gold */
+:root.dark[data-skin="matrix"] .logo {
+  background: linear-gradient(145deg, #00DD33, #00FF41);
+  box-shadow: 0 0 12px rgba(0,255,65,0.3);
+}
+/* New chat button: green solid */
+:root.dark[data-skin="matrix"] .new-chat-btn {
+  background: rgba(0,255,65,0.1);
+  border-color: rgba(0,255,65,0.25);
+  color: #00FF41;
+  font-weight: 600;
+  box-shadow: 0 0 8px rgba(0,255,65,0.08);
+}
+:root.dark[data-skin="matrix"] .new-chat-btn:hover {
+  background: rgba(0,255,65,0.18);
+  border-color: #00FF41;
+  box-shadow: 0 0 14px rgba(0,255,65,0.2);
+}
+/* Send button: green pop with glow */
+:root.dark[data-skin="matrix"] button.send-btn {
+  box-shadow: 0 0 8px rgba(0,255,65,0.2);
+}
+:root.dark[data-skin="matrix"] button.send-btn:hover {
+  box-shadow: 0 0 16px rgba(0,255,65,0.35);
+}
+/* Composer box: green border on focus */
+:root.dark[data-skin="matrix"] .composer-box:focus-within {
+  border-color: var(--accent);
+  box-shadow: 0 0 0 3px rgba(0,255,65,0.1);
+}
+/* Tool cards: green-tinted running state */
+:root.dark[data-skin="matrix"] .tool-card {
+  background: rgba(0,255,65,0.02);
+  border-color: rgba(0,255,65,0.08);
+}
+:root.dark[data-skin="matrix"] .tool-card:hover {
+  border-color: rgba(0,255,65,0.2);
+}
+:root.dark[data-skin="matrix"] .tool-card-running {
+  background: rgba(0,255,65,0.06);
+  border-color: rgba(0,255,65,0.15);
+}
+:root.dark[data-skin="matrix"] .tool-card-running-dot {
+  background: #00FF41;
+  box-shadow: 0 0 6px #00FF41;
+}
+:root.dark[data-skin="matrix"] .tool-card-name {
+  color: var(--accent-text);
+  font-weight: 600;
+}
+:root.dark[data-skin="matrix"] .tool-arg-key {
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .tool-card-more {
+  color: #00FF41;
+}
+/* Thinking cards: green-tinted gold */
+:root.dark[data-skin="matrix"] .thinking-card-loading {
+  border-color: rgba(0,255,65,0.2);
+  background: rgba(0,255,65,0.04);
+}
+:root.dark[data-skin="matrix"] .thinking-dot {
+  background: #00FF41;
+}
+/* User messages: dark green pill */
+:root.dark[data-skin="matrix"] .msg-row[data-role="user"] .msg-body {
+  border-radius: 16px;
+  padding: 12px 16px;
+}
+:root.dark[data-skin="matrix"] .msg-row[data-role="user"] .msg-body code {
+  color: var(--user-bubble-text);
+  background: rgba(0,255,65,0.12);
+}
+/* Role icons: green-tinted */
+:root.dark[data-skin="matrix"] .role-icon.user {
+  background: rgba(0,255,65,0.1);
+  color: #00FF41;
+  border-color: rgba(0,255,65,0.2);
+}
+:root.dark[data-skin="matrix"] .role-icon.assistant {
+  background: rgba(0,255,65,0.03);
+  color: #00CC33;
+  border-color: rgba(0,255,65,0.1);
+}
+:root.dark[data-skin="matrix"] .msg-role.user {
+  color: #00FF41;
+}
+/* Chips and badges: green tint */
+:root.dark[data-skin="matrix"] .chip.model {
+  background: rgba(0,255,65,0.1);
+  border-color: rgba(0,255,65,0.2);
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .project-chip.active {
+  background: rgba(0,255,65,0.1);
+  color: #00FF41;
+  border-color: rgba(0,255,65,0.2);
+}
+/* Panel nav tabs: green active */
+:root.dark[data-skin="matrix"] .nav-tab.active {
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .nav-tab.active::after {
+  background: #00FF41;
+}
+:root.dark[data-skin="matrix"] .nav-tab:hover {
+  color: #66FF66;
+}
+/* Sidebar header icon and text */
+:root.dark[data-skin="matrix"] .sidebar-header h1 {
+  color: var(--accent-text);
+}
+/* Profile chip */
+:root.dark[data-skin="matrix"] .profile-chip {
+  color: #00FF41!important;
+}
+/* Batch mode selections */
+:root.dark[data-skin="matrix"] .session-item.selected {
+  background: rgba(0,255,65,0.08);
+  color: #00FF41;
+}
+/* Scrollbar: green tint */
+:root.dark[data-skin="matrix"] ::-webkit-scrollbar-thumb {
+  background: rgba(0,255,65,0.15);
+}
+:root.dark[data-skin="matrix"] ::-webkit-scrollbar-thumb:hover {
+  background: rgba(0,255,65,0.3);
+}
+:root.dark[data-skin="matrix"] ::selection {
+  background: rgba(0,255,65,0.3);
+}
+/* Prism syntax: green-tinted matrix code */
+:root.dark[data-skin="matrix"] .token.comment,
+:root.dark[data-skin="matrix"] .token.prolog,
+:root.dark[data-skin="matrix"] .token.doctype,
+:root.dark[data-skin="matrix"] .token.cdata {
+  color: #005F00;
+  font-style: italic;
+}
+:root.dark[data-skin="matrix"] .token.punctuation {
+  color: #008F00;
+}
+:root.dark[data-skin="matrix"] .token.property,
+:root.dark[data-skin="matrix"] .token.tag,
+:root.dark[data-skin="matrix"] .token.boolean,
+:root.dark[data-skin="matrix"] .token.number,
+:root.dark[data-skin="matrix"] .token.constant,
+:root.dark[data-skin="matrix"] .token.symbol,
+:root.dark[data-skin="matrix"] .token.deleted {
+  color: #66FF66;
+}
+:root.dark[data-skin="matrix"] .token.selector,
+:root.dark[data-skin="matrix"] .token.attr-name,
+:root.dark[data-skin="matrix"] .token.string,
+:root.dark[data-skin="matrix"] .token.char,
+:root.dark[data-skin="matrix"] .token.builtin,
+:root.dark[data-skin="matrix"] .token.inserted {
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .token.operator,
+:root.dark[data-skin="matrix"] .token.entity,
+:root.dark[data-skin="matrix"] .token.url,
+:root.dark[data-skin="matrix"] .language-css .token.string,
+:root.dark[data-skin="matrix"] .style .token.string {
+  color: #AAEEAA;
+}
+:root.dark[data-skin="matrix"] .token.atrule,
+:root.dark[data-skin="matrix"] .token.attr-value,
+:root.dark[data-skin="matrix"] .token.keyword {
+  color: #88FF88;
+}
+:root.dark[data-skin="matrix"] .token.function,
+:root.dark[data-skin="matrix"] .token.class-name {
+  color: #CCFFCC;
+}
+:root.dark[data-skin="matrix"] .token.regex,
+:root.dark[data-skin="matrix"] .token.important,
+:root.dark[data-skin="matrix"] .token.variable {
+  color: #66FF99;
+}
+/* Active state indicators */
+:root.dark[data-skin="matrix"] .system-health-dot {
+  background: #00FF41;
+  box-shadow: 0 0 0 3px rgba(0,255,65,0.15);
+}
+:root.dark[data-skin="matrix"] .system-health-bar-fill {
+  background: linear-gradient(90deg, #00CC33, #00FF41);
+}
+/* Dialog confirm buttons */
+:root.dark[data-skin="matrix"] .app-dialog-btn.confirm {
+  border-color: #00FF41;
+  background: rgba(0,255,65,0.1);
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .app-dialog-btn.confirm:hover {
+  background: rgba(0,255,65,0.2);
+  border-color: #00FF41;
+}
+/* Date headers pinned */
+:root.dark[data-skin="matrix"] .session-date-header.pinned {
+  color: #00FF41;
+}
+/* Cron status */
+:root.dark[data-skin="matrix"] .cron-status.attention {
+  color: #00FF41;
+}
+/* Kanban matrix green accents */
+:root.dark[data-skin="matrix"] .kanban-badge.priority {
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .kanban-card-assignee {
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .kanban-modal .btn.primary {
+  border-color: #00FF41;
+  background: rgba(0,255,65,0.1);
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .kanban-modal .btn.primary:hover {
+  background: rgba(0,255,65,0.2);
+  border-color: #00FF41;
+}
+/* Batch action bar */
+:root.dark[data-skin="matrix"] .batch-count {
+  color: #00FF41;
+}
+:root.dark[data-skin="matrix"] .batch-select-all-btn {
+  color: #00FF41;
+}
+
+/* ══════════════════════════════════════════════════════════════
+   Power / Relaunch Rail Buttons
+   ══════════════════════════════════════════════════════════════ */
+.power-btn { color: var(--muted); }
+.power-btn:hover { color: #EF4444 !important; background: rgba(239,68,68,0.1) !important; }
+.relaunch-btn { color: var(--muted); }
+.relaunch-btn:hover { color: var(--accent) !important; background: var(--accent-bg) !important; }
+
+/* ══════════════════════════════════════════════════════════════
+   Power Splashscreen (fullscreen overlay)
+   ══════════════════════════════════════════════════════════════ */
+#powerSplash {
+  position: fixed;
+  inset: 0;
+  z-index: 99999;
+  background: var(--bg-1, #0D0D1A);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  animation: powerSplashFadeIn 0.3s ease;
+}
+@keyframes powerSplashFadeIn {
+  from { opacity: 0; }
+  to   { opacity: 1; }
+}
+.power-splash-inner {
+  text-align: center;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 16px;
+}
+.power-splash-icon {
+  color: var(--accent, #B8860B);
+  animation: powerPulse 1.5s ease-in-out infinite;
+}
+.power-splash-icon svg { display: block; }
+@keyframes powerPulse {
+  0%, 100% { opacity: 0.5; transform: scale(1); }
+  50%      { opacity: 1;   transform: scale(1.08); }
+}
+.power-splash-title {
+  font-size: 24px;
+  font-weight: 700;
+  color: var(--text, #E8DCC8);
+}
+.power-splash-msg {
+  font-size: 13px;
+  color: var(--muted, #888);
+  max-width: 300px;
+}
+.power-splash-spinner { margin-top: 8px; }
+.power-spinner {
+  width: 28px;
+  height: 28px;
+  border: 3px solid var(--border, rgba(255,255,255,0.1));
+  border-top-color: var(--accent, #B8860B);
+  border-radius: 50%;
+  animation: powerSpin 0.8s linear infinite;
+}
+@keyframes powerSpin {
+  to { transform: rotate(360deg); }
+}
+.power-splash-btn {
+  margin-top: 8px;
+  padding: 8px 20px;
+  border-radius: 8px;
+  border: 1px solid var(--accent-bg-strong);
+  background: var(--accent-bg);
+  color: var(--accent-text);
+  font-size: 13px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.15s;
+}
+.power-splash-btn:hover {
+  background: var(--accent-bg-strong);
+  transform: translateY(-1px);
+}
+
+/* ══════════════════════════════════════════════════════════════
+   Power Confirm Dialog
+   ══════════════════════════════════════════════════════════════ */
+.power-confirm-overlay {
+  position: fixed;
+  inset: 0;
+  z-index: 100000;
+  background: rgba(0,0,0,0.7);
+  backdrop-filter: blur(4px);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  animation: powerSplashFadeIn 0.15s ease;
+}
+.power-confirm-dialog {
+  background: var(--bg-2, #1a1a2e);
+  border: 1px solid var(--border, rgba(255,255,255,0.1));
+  border-radius: 14px;
+  padding: 24px;
+  max-width: 380px;
+  width: 90%;
+  text-align: center;
+  box-shadow: 0 16px 48px rgba(0,0,0,0.6);
+}
+.power-confirm-title {
+  font-size: 17px;
+  font-weight: 700;
+  color: var(--text, #E8DCC8);
+  margin-bottom: 8px;
+}
+.power-confirm-msg {
+  font-size: 13px;
+  color: var(--muted, #888);
+  line-height: 1.45;
+  margin-bottom: 20px;
+}
+.power-confirm-actions {
+  display: flex;
+  gap: 10px;
+  justify-content: center;
+}
+.power-confirm-btn {
+  padding: 8px 18px;
+  border-radius: 8px;
+  border: 1px solid var(--border, rgba(255,255,255,0.1));
+  background: var(--bg-1, #0D0D1A);
+  color: var(--text, #E8DCC8);
+  font-size: 13px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.15s;
+  min-width: 100px;
+}
+.power-confirm-btn:hover { background: var(--hover-bg); }
+.power-confirm-ok { border-color: var(--accent-bg-strong); background: var(--accent-bg); color: var(--accent-text); }
+.power-confirm-ok:hover { background: var(--accent-bg-strong); }
+.power-confirm-danger { border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.12); color: #EF4444; }
+.power-confirm-danger:hover { background: rgba(239,68,68,0.2); }
+
+/* ═══════════════════════════════════════════════════════════════════════════
+   DIFF VIEWER — Side-by-Side unified-diff renderer
+   ═══════════════════════════════════════════════════════════════════════════ */
+.diff-viewer {
+  font-family: monospace;
+  font-size: 12px;
+  line-height: 1.55;
+  border: 1px solid var(--border, #E0D8C8);
+  border-radius: var(--radius-md, 8px);
+  overflow: hidden;
+  margin: 6px 0;
+}
+.diff-viewer-dark {
+  border-color: rgba(255,255,255,0.1);
+}
+
+/* ── Stats bar ─────────────────────────────────────────────────────────── */
+.diff-stats-bar {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 5px 10px;
+  background: var(--surface, #F3EEE3);
+  border-bottom: 1px solid var(--border, #E0D8C8);
+  font-size: 11px;
+  font-weight: 600;
+  font-family: var(--font-ui, -apple-system, sans-serif);
+}
+.diff-stats-files {
+  color: var(--text, #1A1610);
+  opacity: 0.7;
+}
+.diff-stats-add {
+  color: #16a34a;
+}
+.diff-stats-del {
+  color: #dc2626;
+}
+
+/* ── File section ──────────────────────────────────────────────────────── */
+.diff-file + .diff-file {
+  border-top: 1px solid var(--border, #E0D8C8);
+}
+.diff-filename {
+  padding: 4px 10px;
+  font-size: 11px;
+  font-weight: 600;
+  color: var(--accent, #B8860B);
+  background: var(--surface-subtle, rgba(0,0,0,.025));
+  border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,.08));
+  cursor: pointer;
+  user-select: none;
+}
+.diff-filename:hover {
+  background: var(--surface-subtle-hover, rgba(0,0,0,.045));
+}
+
+/* ── Body wrapper (scrollable) ─────────────────────────────────────────── */
+.diff-body {
+  overflow-x: auto;
+  overflow-y: auto;
+  max-height: 480px;
+}
+
+/* ── Hunk header ───────────────────────────────────────────────────────── */
+.diff-hunk-header {
+  grid-column: 1 / -1;
+  padding: 2px 10px;
+  font-size: 11px;
+  font-weight: 500;
+  color: var(--accent-text, #8B6508);
+  background: var(--accent-bg, rgba(184,134,11,0.08));
+  border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,.08));
+}
+
+/* ── Row grid: old-gutter | old-content | new-gutter | new-content ─────── */
+.diff-row {
+  display: grid;
+  grid-template-columns: 44px 1fr 44px 1fr;
+  min-height: 20px;
+}
+.diff-row:hover {
+  background: rgba(0,0,0,0.02);
+}
+
+/* ── Gutters (line numbers) ────────────────────────────────────────────── */
+.diff-old-gutter,
+.diff-new-gutter {
+  padding: 0 6px;
+  text-align: right;
+  font-size: 11px;
+  color: var(--muted, #5C5344);
+  background: var(--surface-subtle, rgba(0,0,0,.025));
+  border-right: 1px solid var(--border-subtle, rgba(0,0,0,.08));
+  user-select: none;
+  white-space: nowrap;
+  overflow: hidden;
+}
+.diff-new-gutter {
+  border-right: none;
+  border-left: 1px solid var(--border-subtle, rgba(0,0,0,.08));
+}
+
+/* ── Content cells ─────────────────────────────────────────────────────── */
+.diff-old-line,
+.diff-new-line {
+  padding: 0 8px;
+  white-space: pre-wrap;
+  word-break: break-all;
+  font-size: 12px;
+  min-height: 20px;
+}
+.diff-old-line { color: var(--text, #1A1610); }
+.diff-new-line { color: var(--text, #1A1610); }
+
+/* ── Line types ────────────────────────────────────────────────────────── */
+.diff-del {
+  background: rgba(239,68,68,0.08);
+}
+.diff-del .diff-old-line,
+.diff-old-line.diff-del {
+  color: #b91c1c;
+}
+.diff-del-gutter {
+  background: rgba(239,68,68,0.12);
+}
+
+.diff-add {
+  background: rgba(34,197,94,0.08);
+}
+.diff-add .diff-new-line,
+.diff-new-line.diff-add {
+  color: #15803d;
+}
+.diff-add-gutter {
+  background: rgba(34,197,94,0.12);
+}
+
+.diff-empty {
+  background: transparent;
+}
+
+/* ── Dark mode overrides ───────────────────────────────────────────────── */
+@media (prefers-color-scheme: dark) {
+  .diff-viewer {
+    border-color: rgba(255,255,255,0.1);
+  }
+  .diff-stats-bar {
+    background: rgba(0,0,0,0.2);
+    border-bottom-color: rgba(255,255,255,0.06);
+  }
+  .diff-stats-files { color: rgba(255,255,255,0.6); }
+  .diff-filename {
+    background: rgba(0,0,0,0.15);
+    border-bottom-color: rgba(255,255,255,0.06);
+  }
+  .diff-hunk-header {
+    background: rgba(184,134,11,0.12);
+    border-bottom-color: rgba(255,255,255,0.06);
+  }
+  .diff-row:hover { background: rgba(255,255,255,0.03); }
+  .diff-old-gutter, .diff-new-gutter {
+    background: rgba(0,0,0,0.15);
+    border-right-color: rgba(255,255,255,0.06);
+  }
+  .diff-new-gutter { border-left-color: rgba(255,255,255,0.06); }
+  .diff-old-line, .diff-new-line { color: rgba(255,255,255,0.87); }
+  .diff-del {
+    background: rgba(239,68,68,0.12);
+  }
+  .diff-del .diff-old-line,
+  .diff-old-line.diff-del {
+    color: #fca5a5;
+  }
+  .diff-add {
+    background: rgba(34,197,94,0.12);
+  }
+  .diff-add .diff-new-line,
+  .diff-new-line.diff-add {
+    color: #86efac;
+  }
+}
+
