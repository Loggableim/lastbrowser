{
  "name": "lastbrowser",
  "version": "0.2.0",
  "description": "LastBrowser — Productivity Workspace Browser (Wavebox/Sidekick/Zen inspired)",
  "main": "main.js",
  "author": "Pup Cid",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=1 electron .",
    "build": "electron-builder build --win --config electron-builder.config.js",
    "build:dir": "electron-builder build --win --dir --config electron-builder.config.js",
    "dist": "electron-builder build --win --publish=never --config electron-builder.config.js",
    "test:workspace": "node src/test/test-workspace.js"
  },
  "build": {
    "appId": "app.lastbrowser.desktop",
    "productName": "LastBrowser",
    "copyright": "Copyright © 2026 Pup Cid",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "tray.js",
      "sidebar.html",
      "sidebar.js",
      "sidebar.css",
      "assets/**/*",
      "server-launcher.js",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "webui",
        "filter": [
          "server.py",
          "api/**/*",
          "static/**/*",
          "requirements.txt",
          "scripts/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "LastBrowser-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LastBrowser"
    },
    "publish": {
      "provider": "github",
      "owner": "Loggableim",
      "repo": "cids-hermes-webui"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0",
    "sql.js": "^1.14.1"
  }
}
